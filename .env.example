# Copie para api/.env e ajuste conforme o ambiente.
#
# --- Docker Compose ---
#   cp .env.example api/.env
#   docker compose up -d --build
# Dentro do Compose a API usa o host `db` automaticamente (não precisa mudar DATABASE_URL).
#
# --- API no host + só o Postgres no Docker (dev Windows com run_dev.bat) ---
DATABASE_URL=postgresql+psycopg2://orc:orc_dev@localhost:5432/orc

# Em produção, gere uma chave longa e aleatória.
SECRET_KEY=troque-esta-chave-em-producao

ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# Caminho dos JSON de seed (no Compose o volume monta /app/dados_usuario).
SEED_DATA_DIR=../dados_usuario

API_HOST=0.0.0.0
API_PORT=8000

# Opcionais usados pelo docker-compose.yml (podem ficar só no shell / .env da raiz):
# POSTGRES_USER=orc
# POSTGRES_PASSWORD=orc_dev
# POSTGRES_DB=orc
