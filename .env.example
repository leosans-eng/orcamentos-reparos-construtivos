# Copie para api/.env e ajuste conforme necessário.
#
# PostgreSQL (padrão — desenvolvimento e produção):
# 1) Suba o banco: docker compose up -d
# 2) Use a URL abaixo.
DATABASE_URL=postgresql+psycopg2://orc:orc_dev@localhost:5432/orc

# Alternativa só para testes isolados sem Docker (não use em multi-usuário):
# DATABASE_URL=sqlite:///./api/orc_dev.db

# Em produção, gere uma chave longa e aleatória (nunca deixe o padrão).
SECRET_KEY=troque-esta-chave-em-producao

ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
SEED_DATA_DIR=../dados_usuario
API_HOST=0.0.0.0
API_PORT=8000
