# Copie para api/.env e ajuste conforme o ambiente.
#
# Desenvolvimento local (Docker Compose na raiz do projeto):
#   docker compose up -d
DATABASE_URL=postgresql+psycopg2://orc:orc_dev@localhost:5432/orc

# Em produção, use o host/usuário/senha do Postgres da TI e uma SECRET_KEY própria.
SECRET_KEY=troque-esta-chave-em-producao

ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
SEED_DATA_DIR=../dados_usuario
API_HOST=0.0.0.0
API_PORT=8000
