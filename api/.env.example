# Copie para .env na raiz deste repositório:
#   copy .env.example .env
#
# Subida no servidor Windows: run_dev.bat + Docker Desktop
# No PC do Léo (sem Docker no Windows): Postgres no WSL + run_local.bat
# (Compose no servidor define o host do banco como `db` automaticamente.)
#
# run_local.bat / API no host Windows — use localhost:
DATABASE_URL=postgresql+psycopg2://orc:orc_dev@localhost:5432/orc

# Obrigatório em produção: chave longa e aleatória.
SECRET_KEY=troque-esta-chave-em-producao

ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# JSON de seed (montados em /app/dados_usuario no Compose).
SEED_DATA_DIR=dados_usuario

API_HOST=0.0.0.0
API_PORT=8000

# Opcionais do docker-compose.yml:
# POSTGRES_USER=orc
# POSTGRES_PASSWORD=orc_dev
# POSTGRES_DB=orc
# POSTGRES_PORT=5432
